<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.reply.hub</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>ThrottleInterval</key>
  <integer>10</integer>
  <key>WorkingDirectory</key>
  <string>__REPO_ROOT__</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__REPO_ROOT__/tools/scripts/reply_service.sh</string>
  </array>
  <key>StandardOutPath</key>
  <string>__HOME__/Library/Logs/Reply/hub.log</string>
  <key>StandardErrorPath</key>
  <string>__HOME__/Library/Logs/Reply/hub.log</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin</string>
    <key>REPLY_NODE_BIN</key>
    <string>__REPLY_NODE_BIN__</string>
  </dict>
</dict>
</plist>
