# Copy to `chat/.env.local` (gitignored). Loaded after `.env` so you can enable Hatori per machine
# without editing the main env file. See docs/LOCAL_MACHINE_DEPLOYMENT.md (Hatori section).

REPLY_USE_HATORI=1
# When Hatori is started only via its own LaunchAgent (`make install-service` in hatori repo):
# REPLY_HATORI_EXTERNAL=1
