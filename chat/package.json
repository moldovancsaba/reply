{
  "name": "reply-chat",
  "version": "0.5.14",
  "description": "{reply} POC — localhost chat to ask for reply suggestions",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "ingest": "node ingest.js",
    "analyze": "node kyc-agent.js",
    "security:audit": "node security-audit.js",
    "security:fix": "node security-audit.js --fix",
    "annotate": "node annotation-agent.js",
    "fingerprint": "node unified-brain-report.js",
    "channel-bridge:ingest": "node channel-bridge-sidecar.js",
    "verify:openclaw": "node verify_openclaw.js",
