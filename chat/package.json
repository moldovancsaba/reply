    "imapflow": "^1.3.3",
    "libphonenumber-js": "^1.12.42",
    "mailparser": "^3.9.8",
    "mbox-reader": "^1.2.0",
    "ollama": "^0.6.3",
    "playwright": "^1.49.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2"
  },
  "overrides": {
    "onnxruntime-web": "^1.25.1",
    "protobufjs": "^7.5.5"
