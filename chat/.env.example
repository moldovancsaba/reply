# Gemni API Key for the "Refine" feature
# Get one here: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=YOUR_GEMINI_API_KEY

# Port for the chat server
PORT=45311

# Local Ollama for suggestions, refine, annotation, and KYC-style paths.
# Supported tags (pull only what you use):
#   ollama pull gemma3:1b
#   ollama pull granite4:3b
#   ollama pull MichelRosselli/apertus:latest
#   ollama pull qwen2.5:7b
#   ollama pull llama3.2:3b
# Default in chat/ollama-model.js is gemma3:1b (override with REPLY_OLLAMA_MODEL).
# Recommended trio (matches chat/ollama-model.js defaults):
# REPLY_OLLAMA_MODEL=gemma3:1b
# REPLY_KYC_OLLAMA_MODEL=qwen2.5:7b
# REPLY_ANNOTATION_MODEL=granite4:3b
# Max documents per annotate run (worker + npm run annotate).
# REPLY_ANNOTATION_LIMIT=50
# Worker annotation interval in ms (0 = disable sweep). Default 1800000 (30m).
# REPLY_ANNOTATION_INTERVAL_MS=1800000
# Set to 1 to disable periodic annotation in the worker (manual `npm run annotate` still works).
# REPLY_ANNOTATION_DISABLE=
#
# Background suggestion drafts (worker): each inbound iMessage queues the handle; one draft / interval (default 5 min), newest first. Queue file: data/pending-suggestion-draft-queue.json (gitignored).
# REPLY_SUGGEST_DRAFT_INTERVAL_MS=300000
# REPLY_SUGGEST_BACKGROUND_DISABLE=1
# REPLY_INLINE_DRAFT_GENERATE=1
# REPLY_SUGGEST_REGENERATE_IF_DRAFT=1
#
# Ollama HTTP base (reply-engine, KYC, annotation, Refine in gemini-client.js, health probe, scripts).
# Optional if Ollama is not on localhost:11434
# OLLAMA_HOST=http://127.0.0.1:11434

# Optional: iMessage SQLite path. On macOS the default is ~/Library/Messages/chat.db (no need to set if Full Disk Access is granted).
# REPLY_IMESSAGE_DB_PATH=

# Foundation / preflight (structured checks on every /api/system-health; GET /api/preflight for scripts).
# Outbound sends are not blocked on preflight in this build (dashboard stays informational).

# Security policy
REPLY_OPERATOR_TOKEN=change-me
REPLY_SECURITY_REQUIRE_OPERATOR_TOKEN=true
REPLY_SECURITY_LOCAL_WRITES_ONLY=true
REPLY_SECURITY_REQUIRE_HUMAN_APPROVAL=true

# Never enable in production: appends diagnostics to chat/data/debug_token.log (gitignored).
# REPLY_DEBUG_SETTINGS=1

# Optional: verbose hub stdout (service-manager sidecar notes, hourly auto-sync bookends, shutdown line).
# REPLY_DEBUG=1

# ---------------------------------------------------------------------------
# Optional: {hatori} — https://github.com/moldovancsaba/hatori
# Default: sibling folder `<parent-of-reply-repo>/hatori`. Override checkout location with:
# REPLY_HATORI_PROJECT_PATH=/absolute/path/to/hatori
# From reply repo root: `make hatori-clone` then `make hatori-bootstrap` (official script: DB, models, LaunchAgent).
# Per-machine flag without editing this file: copy `.env.local.example` → `.env.local` (gitignored).
# `make hatori-preflight` checks clone, token file, Docker, API health.
# REPLY_USE_HATORI=1
# REPLY_HATORI_PORT=23572
# REPLY_HATORI_EXTERNAL=1

# WhatsApp policy
# OpenClaw account id (must match linked session; default is default)
# REPLY_WHATSAPP_OPENCLAW_ACCOUNT=default
REPLY_WHATSAPP_SEND_TRANSPORT=openclaw_cli
REPLY_WHATSAPP_ALLOW_OPENCLAW_SEND=true
REPLY_WHATSAPP_DESKTOP_FALLBACK_ON_OPENCLAW_FAILURE=false
# WhatsApp Desktop sync (`sync-whatsapp.js`): default ChatStorage path is under ~/Library/Group Containers/…
# REPLY_WHATSAPP_DB_PATH=

# Optional: OpenClaw gateway WebSocket base (e.g. Docker on :18789). When set to ws(s)://…, the hub
# probes http://host:port/healthz for /api/health (avoids WS "pairing required" vs Docker).
# REPLY_OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
# For `openclaw message send` / CLI fallback, set token to match the gateway (e.g. CLAWDBOT_GATEWAY_TOKEN in mvp-factory-control/.env).
# REPLY_OPENCLAW_GATEWAY_TOKEN=

# Optional override for sidecar helper CLI
REPLY_CHANNEL_BRIDGE_ENDPOINT=http://127.0.0.1:3000/api/channel-bridge/inbound

# Unified /api/conversations index: cache TTL for LanceDB scan (ms). 0 = always rebuild.
# REPLY_CONVERSATIONS_INDEX_TTL_MS=12000

# KYC Analyze (Profile → ✨): LLM message sample size and max chunks for notes extraction.
# REPLY_KYC_LLM_MAX_MESSAGES=800
# REPLY_KYC_LLM_MAX_CHUNKS=32
# Use 0 for REPLY_KYC_LLM_MAX_CHUNKS to run all chunks (can be slow on huge threads).

# Outbound (#17): require inbound-verified identity before send. Default off — set true to enforce reply#17.
# REPLY_OUTBOUND_REQUIRE_INBOUND_VERIFIED=true

# Context freshness (#14): half-life (days) + blend of vector relevance vs recency for mail/Gmail-like RAG paths.
# REPLY_CONTEXT_HALF_LIFE_DAYS=21
# REPLY_CONTEXT_RELEVANCE_WEIGHT=0.45
# REPLY_CONTEXT_FRESHNESS_WEIGHT=0.55
