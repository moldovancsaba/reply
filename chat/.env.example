# Gemni API Key for the "Refine" feature
# Get one here: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=YOUR_GEMINI_API_KEY

# Port for the chat server
PORT=45311

# Local Ollama for suggestions, refine, and KYC (default: gemma4:e2b — lightest Gemma 4).
# Pull: ollama pull gemma4:e2b
# Larger Gemma 4: gemma4:e4b, gemma4:26b, gemma4:31b
# If you still have REPLY_OLLAMA_MODEL=llama3.2:3b, it is auto-remapped to gemma4:e2b unless you set:
# REPLY_OLLAMA_MODEL_LEGACY_MAP=my-other-model
# REPLY_OLLAMA_MODEL=gemma4:e2b
# Optional if Ollama is not on localhost:11434
# OLLAMA_HOST=http://127.0.0.1:11434

# Optional: iMessage SQLite path. On macOS the default is ~/Library/Messages/chat.db (no need to set if Full Disk Access is granted).
# REPLY_IMESSAGE_DB_PATH=

# Security policy
REPLY_OPERATOR_TOKEN=change-me
REPLY_SECURITY_REQUIRE_OPERATOR_TOKEN=true
REPLY_SECURITY_LOCAL_WRITES_ONLY=true
REPLY_SECURITY_REQUIRE_HUMAN_APPROVAL=true

# Never enable in production: appends diagnostics to chat/data/debug_token.log (gitignored).
# REPLY_DEBUG_SETTINGS=1

# Optional: verbose hub stdout (service-manager sidecar notes, hourly auto-sync bookends, shutdown line).
# REPLY_DEBUG=1

# WhatsApp policy
# OpenClaw account id (must match linked session; default is default)
# REPLY_WHATSAPP_OPENCLAW_ACCOUNT=default
REPLY_WHATSAPP_SEND_TRANSPORT=openclaw_cli
REPLY_WHATSAPP_ALLOW_OPENCLAW_SEND=true
REPLY_WHATSAPP_DESKTOP_FALLBACK_ON_OPENCLAW_FAILURE=false

# Optional override for sidecar helper CLI
REPLY_CHANNEL_BRIDGE_ENDPOINT=http://127.0.0.1:3000/api/channel-bridge/inbound

# Unified /api/conversations index: cache TTL for LanceDB scan (ms). 0 = always rebuild.
# REPLY_CONVERSATIONS_INDEX_TTL_MS=12000

# KYC Analyze (Profile → ✨): LLM message sample size and max chunks for notes extraction.
# REPLY_KYC_LLM_MAX_MESSAGES=800
# REPLY_KYC_LLM_MAX_CHUNKS=32
# Use 0 for REPLY_KYC_LLM_MAX_CHUNKS to run all chunks (can be slow on huge threads).

# Outbound (#17): require inbound-verified identity before send (default true). Set false for local dev only.
# REPLY_OUTBOUND_REQUIRE_INBOUND_VERIFIED=false

# Context freshness (#14): half-life (days) + blend of vector relevance vs recency for mail/Gmail-like RAG paths.
# REPLY_CONTEXT_HALF_LIFE_DAYS=21
# REPLY_CONTEXT_RELEVANCE_WEIGHT=0.45
# REPLY_CONTEXT_FRESHNESS_WEIGHT=0.55
