# Copy to `chat/.env.local` (gitignored). Loaded after `.env` so you can enable Hatori per machine
# without editing the main env file. See docs/LOCAL_MACHINE_DEPLOYMENT.md (Hatori section).

# Optional: override Ollama models per machine (see chat/.env for the recommended trio).
# REPLY_OLLAMA_MODEL=llama3.2:3b
# REPLY_KYC_OLLAMA_MODEL=qwen2.5:7b
# REPLY_ANNOTATION_MODEL=granite4:3b

REPLY_USE_HATORI=1
# When Hatori is started only via its own LaunchAgent (`make install-service` in hatori repo):
# REPLY_HATORI_EXTERNAL=1
# Pin checkout for hub-managed spawn (optional if default sibling path is correct):
# REPLY_HATORI_PROJECT_PATH=/Users/Shared/Projects/hatori

# Optional: Docker OpenClaw on a remapped host port (see docs/openclaw_playbook.md).
# REPLY_OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18790
# REPLY_OPENCLAW_GATEWAY_TOKEN=
